@model IEnumerable<SportnaSila.Models.Products>

@{
    ViewData["Title"] = "Продукти";
}

<section class="page-header">
    <div class="container">
        <h1>Нашите продукти</h1>
        <p>Разгледай наличната спортна екипировка, аксесоари и предложения.</p>
    </div>
</section>

<section class="pb-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
            <a asp-action="Create" class="btn btn-main">
                Добави нов продукт
            </a>
        </div>

        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="product-card">
                        <img src="@(string.IsNullOrEmpty(item.ImgUrl) ? "https://via.placeholder.com/600x400?text=SportnaSila" : item.ImgUrl)"
                             alt="@item.Name"
                             class="product-image" />

                        <div class="product-body">
                            <h3 class="product-title">@item.Name</h3>

                            <p class="product-description">
                                @item.Description
                            </p>

                            <div class="product-meta">
                                <strong>Количество:</strong> @item.Quantity
                            </div>

                            <div class="product-meta">
                                <strong>Категория:</strong> @(item.Category != null ? item.Category.Name : "Няма")
                            </div>

                            <div class="product-meta">
                                <strong>Марка:</strong> @(item.Brand != null ? item.Brand.BrandName : "Няма")
                            </div>

                            <div class="d-flex justify-content-between align-items-center mt-3">

                                <span class="product-price text-success fw-bold">
                                    @item.Price.ToString("0.00") €
                                </span>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-dark">
                                    Детайли
                                </a>
                            </div>

                            <div class="admin-actions mt-3">
                                <a asp-action="Edit" asp-route-id="@item.Id">Редакция</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="text-danger">Изтрий</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>