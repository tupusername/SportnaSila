@model IEnumerable<SportnaSila.Models.Products>

@{
    ViewData["Title"] = "Продукти";
}

<section class="page-header">
    <div class="container">
        <h1>Нашите продукти</h1>
        <p>Разгледай наличната спортна екипировка, аксесоари и предложения.</p>
    </div>
</section>

<section class="pb-5">
    <div class="container">

        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Create" class="btn btn-main">
                    Добави нов продукт
                </a>
            }
        </div>

        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4">

                    <!-- ЦЯЛАТА КАРТА Е CLICKABLE -->
                    <div class="product-card"
                         onclick="window.location='@Url.Action("Details", "Products", new { id = item.Id })'">

                        <img src="@(string.IsNullOrEmpty(item.ImgUrl) ? "https://via.placeholder.com/600x400?text=SportnaSila" : item.ImgUrl)"
                             alt="@item.Name"
                             class="product-image" />

                        <div class="product-body">
                            <h3 class="product-title">@item.Name</h3>

                            <p class="product-description">
                                @item.Description
                            </p>

                            <div class="product-meta">
                                <strong>Количество:</strong> @item.Quantity
                            </div>

                            <div class="product-meta">
                                <strong>Категория:</strong> @(item.Category != null ? item.Category.Name : "Няма")
                            </div>

                            <div class="product-meta">
                                <strong>Марка:</strong> @(item.Brand != null ? item.Brand.BrandName : "Няма")
                            </div>

                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <span class="product-price">@item.Price.ToString("0.00") €</span>
                                <span class="btn btn-outline-dark">Детайли</span>
                            </div>

                            @if (User.IsInRole("Admin"))
                            {
                                <div class="admin-actions mt-3">
                                    <a asp-action="Edit"
                                       asp-route-id="@item.Id"
                                       onclick="event.stopPropagation();">
                                        Редакция
                                    </a>

                                    <a asp-action="Delete"
                                       asp-route-id="@item.Id"
                                       class="text-danger"
                                       onclick="event.stopPropagation();">
                                        Изтрий
                                    </a>
                                </div>
                            }
                        </div>
                    </div>

                </div>
            }
        </div>

    </div>
</section>